# ============================================================
# CLÉ PARIS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase (client, exposed to browser) ───────────────────
# Found in: Supabase Dashboard → Settings → API
# The anon key is safe in the browser — RLS enforces access.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (server-only, Netlify Functions) ───────────────
# NEVER prefix with VITE_ and NEVER commit. Used by the checkout
# webhook + admin-invite functions to bypass RLS with full access.
# SUPABASE_URL can be omitted if VITE_SUPABASE_URL is set.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ───────────────────────────────────────────────────
# Server-only secret (Netlify Functions). NEVER prefix with VITE_.
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
# Webhook signing secret: Stripe → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ── Shipping (optional, used by create-checkout) ─────────────
FREE_SHIPPING_THRESHOLD=150
SHIPPING_FLAT_EUR=9.90

# ── App ──────────────────────────────────────────────────────
VITE_SITE_URL=http://localhost:5173
